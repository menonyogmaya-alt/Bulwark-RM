<script>
function openMenu(){document.getElementById('mobileMenu').classList.add('open');}
function closeMenu(){document.getElementById('mobileMenu').classList.remove('open');}
function goTo(id){
  closeMenu();
  const el=document.getElementById(id);
  if(!el)return;
  const top=el.getBoundingClientRect().top+window.pageYOffset-68;
  window.scrollTo({top:Math.max(0,top),behavior:'smooth'});
  // fallback for iframe environments
  setTimeout(()=>el.scrollIntoView({behavior:'smooth',block:'start'}),50);
}

const sIds=['home','calculator','analysis','alerts','suggestions'];
window.addEventListener('scroll',()=>{
  let cur='home';
  sIds.forEach(id=>{const el=document.getElementById(id);if(el&&window.scrollY>=el.offsetTop-80)cur=id;});
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.toggle('active',a.dataset.s===cur));
},{passive:true});

function updateAge(v){document.getElementById('ageDisplay').textContent=v+' years';}

function calculateRisk(){
  const age=+document.getElementById('ageSlider').value;
  const horizon=+document.getElementById('horizonSelect').value;
  const emergency=+document.getElementById('emergencySelect').value;
  const stocks=+document.getElementById('stockPct').value||0;
  const mf=+document.getElementById('mfPct').value||0;
  const gold=+document.getElementById('goldPct').value||0;
  const fd=+document.getElementById('fdPct').value||0;
  const re=+document.getElementById('rePct').value||0;
  const crypto=+document.getElementById('cryptoPct').value||0;
  const total=stocks+mf+gold+fd+re+crypto;
  const warn=document.getElementById('totalWarn');
  if(Math.abs(total-100)>5&&total>0){warn.style.display='block';return;}
  warn.style.display='none';

  const ageS=age<30?15:age<40?30:age<50?50:age<60?65:80;
  const eq=stocks+mf*0.6;
  const eqS=eq>70?75:eq>50?55:eq>30?35:15;
  const cS=crypto>15?85:crypto>8?65:crypto>3?35:0;
  const emgS=emergency===0?30:emergency===1?18:emergency===2?5:0;
  const hS=horizon===1?28:horizon===2?14:4;
  let sc=Math.round(eqS*0.35+cS*0.15+emgS*0.15+ageS*0.25+hS*0.10);
  sc=Math.min(Math.max(sc,4),95);

  document.getElementById('rPlaceholder').style.display='none';
  document.getElementById('rBody').style.display='block';
  document.getElementById('rScore').textContent=sc;
  setTimeout(()=>{
    document.getElementById('sFill').style.width=sc+'%';
    document.getElementById('sDot').style.left=sc+'%';
  },50);

  const badge=document.getElementById('rBadge');
  let bSt,bTx,desc;
  if(sc<33){
    bSt='background:rgba(76,175,80,0.12);color:#388e3c;border-color:#388e3c;';
    bTx='Conservative Profile';
    desc='Your portfolio carries relatively low risk. You prioritise capital preservation over high returns — appropriate for investors near retirement or with short-term goals. Consider a modest equity allocation as a long-term inflation hedge.';
  }else if(sc<66){
    bSt='background:rgba(255,152,0,0.1);color:#d04a00;border-color:#ff9800;';
    bTx='Moderate Profile';
    desc='Your portfolio carries moderate risk — a balanced mix of growth and stability appropriate for most Indian investors aged 30–50. Review emergency fund adequacy and consider annual rebalancing.';
  }else{
    bSt='background:rgba(239,83,80,0.1);color:#b71c1c;border-color:#ef5350;';
    bTx='Aggressive Profile';
    desc='Your portfolio carries high risk. While this may generate higher long-term returns, significant short-term drawdowns are possible. Ensure you have a robust emergency fund and consider adding debt or gold instruments.';
  }
  badge.setAttribute('style',bSt);badge.textContent='● '+bTx;
  document.getElementById('rDesc').textContent=desc;

  const factors=[
    {n:'Age Factor',v:ageS,l:age<35?'Young investor':age<50?'Mid-career':'Pre-retirement'},
    {n:'Equity Exposure',v:eqS,l:Math.round(eq)+'% in equity'},
    {n:'Crypto Holdings',v:cS,l:crypto+'% in crypto'},
    {n:'Emergency Fund',v:30-emgS,l:['No fund ⚠','1–2 months','3–6 months ✓','6+ months ✓'][emergency]},
    {n:'Time Horizon',v:30-hS,l:['< 1 year','1–3 years','3–7 years','7–15 years','15+ years'][horizon-1]},
  ];
  const ft=document.getElementById('fTable');
  ft.innerHTML='<tr><td colspan="3" style="font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#546e7a;padding-bottom:0.5rem;">Contributing Factors</td></tr>';
  factors.forEach(f=>{
    const cls=f.v>60?'ftag-h':f.v>35?'ftag-m':'ftag-l';
    const lbl=f.v>60?'High':f.v>35?'Moderate':'Low';
    ft.innerHTML+=`<tr><td>${f.n}</td><td style="color:#90a4ae">${f.l}</td><td><span class="ftag ${cls}">${lbl}</span></td></tr>`;
  });

  const alerts=[];
  if(crypto>10)alerts.push('Crypto allocation ('+crypto+'%) exceeds recommended maximum of 5%. Consider reducing this exposure.');
  if(stocks>60)alerts.push('Direct equity at '+stocks+'% is highly concentrated. Consider diversifying into index funds or mutual funds.');
  if(emergency===0)alerts.push('No emergency fund detected. This is the most critical financial safety net — establish one before increasing investment exposure.');
  if(fd+gold<10&&sc>50)alerts.push('Safe assets (FD + Gold) below 10%. Adding 10–20% in debt instruments would meaningfully improve portfolio stability.');
  if(horizon<=2&&eq>50)alerts.push('Short investment horizon (under 3 years) combined with high equity exposure is inadvisable. Consider shifting to liquid or short-term debt funds.');
  const da=document.getElementById('dynAlert'),dc=document.getElementById('dynContent');
  if(alerts.length){
    da.style.display='block';
    dc.innerHTML=alerts.map(a=>`<div class="dyn-item">→ ${a}</div>`).join('');
  }else{da.style.display='none';}
}

let donutC,barC;
const LABS=['Equity','Mutual Funds','Gold','FD / Debt','Real Estate','Crypto','Cash'];
const COLS=['#1c5fa0','#3d8cb5','#c9a84c','#2e7d5e','#6d4fa0','#b03a3a','#6b7280'];
const RW=[8,5,2,1,2,12,0.1];

function getVals(){
  return[
    +document.getElementById('aStocks').value||0,
    +document.getElementById('aMF').value||0,
    +document.getElementById('aGold').value||0,
    +document.getElementById('aFD').value||0,
    +document.getElementById('aRE').value||0,
    +document.getElementById('aCrypto').value||0,
    +document.getElementById('aCash').value||0,
  ];
}

function initCharts(){
  const v=getVals();
  donutC=new Chart(document.getElementById('portfolioDonut').getContext('2d'),{
    type:'doughnut',
    data:{labels:LABS,datasets:[{data:v,backgroundColor:COLS,borderWidth:2,borderColor:'#fff',hoverOffset:5}]},
    options:{cutout:'60%',plugins:{legend:{position:'bottom',labels:{color:'#374151',font:{size:10,family:'Source Sans 3'},padding:8}},tooltip:{callbacks:{label:c=>` ${c.label}: ${c.parsed}%`}}}}
  });
  barC=new Chart(document.getElementById('riskBar').getContext('2d'),{
    type:'bar',
    data:{labels:LABS,datasets:[{label:'Risk contribution',data:v.map((x,i)=>+((x*RW[i])/100).toFixed(2)),backgroundColor:COLS,borderRadius:2,borderWidth:0}]},
    options:{indexAxis:'y',plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(0,0,0,0.05)'},ticks:{color:'#6b7280',font:{size:10}}},y:{grid:{display:false},ticks:{color:'#374151',font:{size:10,family:'Source Sans 3'}}}}}
  });
}

function updateCharts(){
  const v=getVals();
  document.getElementById('aTotal').value=v.reduce((a,b)=>a+b,0);
  if(donutC){donutC.data.datasets[0].data=v;donutC.update();}
  if(barC){barC.data.datasets[0].data=v.map((x,i)=>+((x*RW[i])/100).toFixed(2));barC.update();}
  const nz=v.filter(x=>x>0).length,mx=Math.max(...v);
  let ds=Math.min(nz*12,60);
  if(mx<30)ds+=20;else if(mx<50)ds+=10;
  if(v[2]>=5)ds+=10;if(v[3]+v[6]>=10)ds+=10;
  ds=Math.min(ds,100);
  const dn=document.getElementById('divScoreNum');
  dn.textContent=ds;
  dn.style.color=ds>=70?'#2e7d32':ds>=45?'#d04a00':'#b71c1c';
  let dd,da;
  if(ds>=70){dd='Strong diversification across multiple asset classes. Your portfolio is well-positioned to absorb sector-specific or market-wide shocks.';da='Recommendation: Maintain this allocation and rebalance annually to preserve these ratios.';}
  else if(ds>=45){dd='Moderate diversification. Some spread exists, but concentration in certain asset classes may amplify risk during downturns.';da='Recommendation: Increase allocation to underweight classes such as gold and debt to improve your score.';}
  else{dd='Low diversification. Heavy concentration in one or two asset classes significantly amplifies portfolio risk.';da='Action Required: Distribute across at least 4–5 asset classes including equity, debt, gold, and liquid instruments.';}
  document.getElementById('divScoreDesc').textContent=dd;
  document.getElementById('divAdvice').textContent=da;
}

function showTab(id,btn){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}

window.addEventListener('DOMContentLoaded',()=>{initCharts();updateCharts();});
</script>
</body>
</html>
