<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NiveshRaksha – Portfolio Risk Management</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'Source Sans 3',sans-serif;background:#f4f1eb;color:#1a1a1a;min-height:100vh;}

nav{position:fixed;top:0;left:0;right:0;z-index:200;background:#1c2b3a;border-bottom:2px solid #c9a84c;}
.nav-inner{max-width:1100px;margin:0 auto;padding:0 2rem;height:60px;display:flex;align-items:center;justify-content:space-between;}
.logo{font-family:'Playfair Display',serif;font-size:1.35rem;font-weight:600;color:#c9a84c;letter-spacing:0.02em;text-decoration:none;}
.logo span{color:#fff;font-weight:400;}
.nav-links{display:flex;list-style:none;}
.nav-links a{color:#b0bec5;text-decoration:none;font-size:0.8rem;font-weight:500;letter-spacing:0.05em;padding:0 0.9rem;line-height:60px;border-bottom:2px solid transparent;margin-bottom:-2px;transition:color 0.2s,border-color 0.2s;text-transform:uppercase;}
.nav-links a:hover{color:#fff;}
.nav-links a.active{color:#c9a84c;border-bottom-color:#c9a84c;}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px;}
.hamburger span{display:block;width:22px;height:2px;background:#b0bec5;border-radius:1px;}

.hero-banner{background:#1c2b3a;padding:5rem 2rem 4rem;text-align:center;border-bottom:2px solid #c9a84c;margin-top:60px;}
.section-tag{display:inline-block;border:1px solid #c9a84c;color:#c9a84c;font-size:0.68rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.3rem 1rem;margin-bottom:1.5rem;}
.hero-banner h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.2rem);font-weight:600;color:#fff;line-height:1.2;margin-bottom:1rem;}
.hero-banner h1 em{color:#c9a84c;font-style:italic;}
.hero-banner p{color:#b0bec5;font-size:1rem;max-width:540px;margin:0 auto 2rem;line-height:1.7;font-weight:300;}
.hero-cta{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}
.btn-gold{background:#c9a84c;color:#1c2b3a;border:none;padding:0.7rem 1.8rem;font-family:'Source Sans 3',sans-serif;font-size:0.82rem;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;cursor:pointer;transition:background 0.2s;}
.btn-gold:hover{background:#dfc070;}
.btn-outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.3);padding:0.7rem 1.8rem;font-family:'Source Sans 3',sans-serif;font-size:0.82rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;cursor:pointer;transition:border-color 0.2s,color 0.2s;}
.btn-outline:hover{border-color:#c9a84c;color:#c9a84c;}

.stat-strip{background:#fff;border-bottom:1px solid #ddd;}
.stat-strip-inner{max-width:1100px;margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:repeat(4,1fr);}
.stat-item{text-align:center;padding:1.75rem 1rem;border-right:1px solid #ede9e0;}
.stat-item:last-child{border-right:none;}
.stat-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:600;color:#1c2b3a;}
.stat-label{font-size:0.72rem;color:#6b7280;margin-top:0.3rem;line-height:1.4;}

.page-section{padding:4rem 2rem;}
.section-inner{max-width:1100px;margin:0 auto;}
.section-header{margin-bottom:2rem;}
.section-eyebrow{font-size:0.68rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:#c9a84c;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.6rem;}
.section-eyebrow::before{content:'';display:inline-block;width:18px;height:1px;background:#c9a84c;}
.section-header h2{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:500;color:#1c2b3a;line-height:1.25;}
.section-header p{color:#4b5563;font-size:0.9rem;margin-top:0.4rem;max-width:580px;line-height:1.7;}

.feature-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:1.5rem;}
.feature-card{background:#fff;border:1px solid #e0d9cc;padding:2rem;position:relative;}
.feature-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:#c9a84c;}
.feature-icon{width:40px;height:40px;background:#f4f1eb;border:1px solid #e0d9cc;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:1rem;}
.feature-card h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:500;color:#1c2b3a;margin-bottom:0.4rem;}
.feature-card p{font-size:0.82rem;color:#4b5563;line-height:1.6;}

.section-alt{background:#fff;}

.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;}
.form-panel{background:#f4f1eb;border:1px solid #ddd9ce;padding:2rem;}
.form-panel h3{font-family:'Playfair Display',serif;font-size:0.9rem;font-weight:500;color:#1c2b3a;margin-bottom:1.25rem;padding-bottom:0.75rem;border-bottom:1px solid #ddd9ce;text-transform:uppercase;letter-spacing:0.08em;}
.form-group{margin-bottom:1rem;}
label{display:block;font-size:0.74rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em;}
input[type="number"],select{width:100%;background:#fff;border:1px solid #ccc5b6;color:#1a1a1a;font-family:'Source Sans 3',sans-serif;font-size:0.88rem;padding:0.5rem 0.75rem;outline:none;transition:border-color 0.2s;appearance:none;border-radius:0;}
input:focus,select:focus{border-color:#c9a84c;}
input[type="range"]{width:100%;padding:0.25rem 0;cursor:pointer;accent-color:#c9a84c;background:none;border:none;outline:none;}
.range-row{display:flex;justify-content:space-between;font-size:0.68rem;color:#6b7280;margin-top:0.15rem;}
.inv-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.6rem;}

.result-panel{background:#1c2b3a;padding:2rem;position:sticky;top:80px;}
.result-placeholder{text-align:center;padding:3rem 1rem;color:#546e7a;}
.ph-icon{font-size:2.5rem;margin-bottom:1rem;opacity:0.35;display:block;}
.result-placeholder p{font-size:0.82rem;line-height:1.6;}
.result-body{display:none;}
.profile-badge{display:inline-flex;align-items:center;gap:0.4rem;padding:0.25rem 0.8rem;font-size:0.68rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:0.6rem;border:1px solid;}
.score-num{font-family:'Playfair Display',serif;font-size:4rem;font-weight:600;color:#c9a84c;line-height:1;}
.score-sub{font-size:0.72rem;color:#546e7a;margin-top:0.15rem;}
.score-track{height:6px;background:rgba(255,255,255,0.08);margin:1.25rem 0 0.4rem;position:relative;}
.score-fill{height:100%;background:linear-gradient(90deg,#4caf50,#ff9800,#ef5350);transition:width 1s ease;}
.score-dot{position:absolute;top:-5px;width:16px;height:16px;background:#c9a84c;border-radius:50%;border:2px solid #1c2b3a;transition:left 1s ease;transform:translateX(-50%);}
.track-labels{display:flex;justify-content:space-between;font-size:0.63rem;color:#546e7a;margin-bottom:1.25rem;}
.result-desc{background:rgba(201,168,76,0.08);border-left:2px solid #c9a84c;padding:0.75rem 1rem;font-size:0.8rem;color:#b0bec5;line-height:1.6;margin-bottom:1.25rem;}
.factor-table{width:100%;font-size:0.76rem;border-collapse:collapse;}
.factor-table td{padding:0.45rem 0;border-bottom:1px solid rgba(255,255,255,0.06);color:#b0bec5;vertical-align:middle;}
.factor-table td:first-child{color:#78909c;width:40%;}
.factor-table tr:last-child td{border-bottom:none;}
.ftag{font-size:0.6rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:0.15rem 0.45rem;border:1px solid;float:right;}
.ftag-h{color:#ef5350;border-color:#ef5350;}
.ftag-m{color:#ff9800;border-color:#ff9800;}
.ftag-l{color:#66bb6a;border-color:#66bb6a;}
.warn-box{background:#fff3f3;border:1px solid #f5c6c6;padding:0.6rem 0.8rem;font-size:0.78rem;color:#c62828;margin-top:0.5rem;display:none;}

.alloc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin:1.5rem 0;}
.alloc-item{background:#fff;border:1px solid #e0d9cc;padding:1rem;text-align:center;}
.alloc-emoji{font-size:1.3rem;display:block;margin-bottom:0.35rem;}
.alloc-item label{font-size:0.65rem;}
.alloc-item input{text-align:center;font-weight:600;padding:0.4rem;margin-top:0.35rem;}

.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-top:1.5rem;}
.chart-box{background:#fff;border:1px solid #e0d9cc;padding:1.5rem;}
.chart-box h3{font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.09em;color:#374151;margin-bottom:0.25rem;}
.chart-sub{font-size:0.7rem;color:#6b7280;margin-bottom:1rem;}
.chart-box canvas{max-height:200px;}

.div-score-box{background:#fff;border:1px solid #e0d9cc;border-left:3px solid #c9a84c;padding:1.75rem;display:flex;align-items:center;gap:2rem;margin-top:1.5rem;flex-wrap:wrap;}
.div-score-num{font-family:'Playfair Display',serif;font-size:3.5rem;font-weight:600;color:#1c2b3a;line-height:1;min-width:75px;}
.div-score-info{flex:1;}
.div-score-info p{font-size:0.85rem;color:#374151;line-height:1.6;}
.div-advice{background:#f4f1eb;border:1px solid #ddd9ce;padding:0.6rem 0.9rem;font-size:0.78rem;color:#374151;margin-top:0.5rem;line-height:1.5;}

.alert-list{display:flex;flex-direction:column;gap:0.75rem;margin-top:1.5rem;}
.alert-card{display:flex;align-items:flex-start;gap:1.25rem;background:#fff;border:1px solid #e0d9cc;border-left:3px solid #ddd;padding:1.25rem;}
.alert-card.high{border-left-color:#ef5350;}
.alert-card.med{border-left-color:#ff9800;}
.alert-card.low{border-left-color:#66bb6a;}
.alert-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;margin-top:6px;}
.dot-h{background:#ef5350;}.dot-m{background:#ff9800;}.dot-l{background:#66bb6a;}
.alert-body{flex:1;}
.alert-title{font-size:0.88rem;font-weight:600;color:#1c2b3a;margin-bottom:0.3rem;}
.alert-desc{font-size:0.78rem;color:#4b5563;line-height:1.55;}
.sev-tag{font-size:0.6rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;padding:0.2rem 0.55rem;border:1px solid;flex-shrink:0;align-self:flex-start;white-space:nowrap;}
.sev-h{color:#ef5350;border-color:#ef5350;}.sev-m{color:#ff9800;border-color:#ff9800;}.sev-l{color:#66bb6a;border-color:#66bb6a;}

.dynamic-alert{background:#fff;border:1px solid #e0d9cc;border-top:3px solid #c9a84c;padding:1.5rem;margin-top:1.5rem;display:none;}
.dynamic-alert h3{font-family:'Playfair Display',serif;font-size:1rem;font-weight:500;color:#1c2b3a;margin-bottom:0.75rem;}
.dyn-item{font-size:0.8rem;color:#374151;padding:0.45rem 0;border-bottom:1px solid #f0ece4;line-height:1.5;}
.dyn-item:last-child{border-bottom:none;}

.tab-nav{display:flex;border-bottom:2px solid #ddd9ce;margin-bottom:1.5rem;flex-wrap:wrap;}
.tab-btn{background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-2px;font-family:'Source Sans 3',sans-serif;font-size:0.78rem;font-weight:600;color:#6b7280;letter-spacing:0.06em;text-transform:uppercase;padding:0.7rem 1rem;cursor:pointer;transition:color 0.2s,border-color 0.2s;}
.tab-btn:hover{color:#1c2b3a;}
.tab-btn.active{color:#1c2b3a;border-bottom-color:#c9a84c;}
.tab-content{display:none;}
.tab-content.active{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
.sug-card{background:#fff;border:1px solid #e0d9cc;padding:1.5rem;position:relative;}
.sug-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:#c9a84c;}
.sug-emoji{font-size:1.4rem;display:block;margin-bottom:0.7rem;}
.sug-card h3{font-family:'Playfair Display',serif;font-size:0.95rem;font-weight:500;color:#1c2b3a;margin-bottom:0.35rem;}
.sug-card p{font-size:0.78rem;color:#4b5563;line-height:1.55;}
.sug-tag{display:inline-block;margin-top:0.7rem;font-size:0.6rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.18rem 0.55rem;background:#f4f1eb;color:#6b7280;border:1px solid #ddd9ce;}

footer{background:#111c26;border-top:2px solid #c9a84c;padding:2.5rem 2rem;text-align:center;}
.footer-logo{font-family:'Playfair Display',serif;font-size:1.1rem;color:#c9a84c;margin-bottom:0.75rem;}
.disclaimer-box{max-width:660px;margin:0 auto 1.25rem;background:rgba(201,168,76,0.05);border:1px solid rgba(201,168,76,0.2);padding:1rem 1.25rem;font-size:0.74rem;color:#78909c;line-height:1.65;}
footer p{font-size:0.76rem;color:#546e7a;line-height:1.7;}

.mobile-menu{display:none;position:fixed;inset:0;z-index:199;background:#1c2b3a;flex-direction:column;align-items:center;justify-content:center;gap:1.5rem;}
.mobile-menu.open{display:flex;}
.mobile-menu a{color:#fff;text-decoration:none;font-size:1.2rem;font-family:'Playfair Display',serif;}
.mobile-menu a:hover{color:#c9a84c;}
.mobile-close{position:absolute;top:1.25rem;right:1.5rem;background:none;border:1px solid rgba(255,255,255,0.2);color:#b0bec5;width:36px;height:36px;font-size:1rem;cursor:pointer;}

.gold-rule{height:2px;background:#c9a84c;max-width:48px;margin:0 auto 2rem;}

@media(max-width:768px){
  .nav-links{display:none;}.hamburger{display:flex;}
  .stat-strip-inner{grid-template-columns:1fr 1fr;}
  .stat-item{border-bottom:1px solid #ede9e0;}
  .stat-item:nth-child(2){border-right:none;}
  .stat-item:last-child,.stat-item:nth-last-child(2){border-bottom:none;}
  .feature-grid{grid-template-columns:1fr;}
  .calc-grid{grid-template-columns:1fr;}
  .inv-grid{grid-template-columns:1fr 1fr;}
  .alloc-grid{grid-template-columns:repeat(2,1fr);}
  .charts-row{grid-template-columns:1fr;}
  .tab-content.active{grid-template-columns:1fr;}
  .div-score-box{flex-direction:column;gap:1rem;}
  .hero-cta{flex-direction:column;align-items:center;}
}
</style>
</head>
