<!-- HOME -->
<div id="home">
  <div class="hero-banner">
    <div class="section-tag">Portfolio Risk Management · India</div>
    <h1>Understand and manage<br>your investment <em>risk</em></h1>
    <p>A structured tool to assess your risk profile, analyse your portfolio, and receive evidence-based guidance — designed for Indian investors.</p>
    <div class="hero-cta">
      <button class="btn-gold" onclick="goTo('calculator')">Begin Risk Assessment</button>
      <button class="btn-outline" onclick="goTo('analysis')">Analyse My Portfolio</button>
    </div>
  </div>

  <div class="stat-strip">
    <div class="stat-strip-inner">
      <div class="stat-item"><div class="stat-num">₹7.4T</div><div class="stat-label">Lost to avoidable risk by retail investors (FY24)</div></div>
      <div class="stat-item"><div class="stat-num">68%</div><div class="stat-label">Investors who have never formally assessed portfolio risk</div></div>
      <div class="stat-item"><div class="stat-num">5 min</div><div class="stat-label">Time to receive your personalised risk score</div></div>
      <div class="stat-item"><div class="stat-num">Free</div><div class="stat-label">No registration or hidden charges required</div></div>
    </div>
  </div>

  <div class="page-section">
    <div class="section-inner">
      <div class="section-header" style="text-align:center">
        <div class="section-eyebrow" style="justify-content:center">What This Tool Covers</div>
        <h2>Four steps to a better-protected portfolio</h2>
      </div>
      <div class="gold-rule"></div>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">🎯</div>
          <h3>Risk Score</h3>
          <p>Answer questions about your age, income, investments, and goals. Receive a score from 0 to 100 with a detailed factor breakdown.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>Portfolio Analysis</h3>
          <p>Visualise your allocation across stocks, mutual funds, gold, FD, real estate, and crypto. Receive a diversification score instantly.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💡</div>
          <h3>Strategies and Alerts</h3>
          <p>Understand the most common risks facing Indian investors and receive practical, step-by-step strategies to reduce them.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CALCULATOR -->
<div id="calculator" class="page-section section-alt">
  <div class="section-inner">
    <div class="section-header">
      <div class="section-eyebrow">Step 1 of 4</div>
      <h2>Risk Calculator</h2>
      <p>Provide details about your finances and current investments. The tool will generate a personalised risk profile based on your inputs.</p>
    </div>
    <div class="calc-grid">
      <div>
        <div class="form-panel">
          <h3>Personal Information</h3>
          <div class="form-group">
            <label>Your Age — <span id="ageDisplay" style="color:#c9a84c;font-weight:700">30 years</span></label>
            <input type="range" id="ageSlider" min="18" max="70" value="30" oninput="updateAge(this.value)">
            <div class="range-row"><span>18</span><span>70</span></div>
          </div>
          <div class="form-group">
            <label>Monthly Income</label>
            <select id="incomeSelect">
              <option value="1">Below ₹25,000</option>
              <option value="2" selected>₹25,000 – ₹75,000</option>
              <option value="3">₹75,000 – ₹1,50,000</option>
              <option value="4">₹1,50,000 – ₹5,00,000</option>
              <option value="5">Above ₹5,00,000</option>
            </select>
          </div>
          <div class="form-group">
            <label>Investment Horizon</label>
            <select id="horizonSelect">
              <option value="1">Less than 1 year</option>
              <option value="2">1 – 3 years</option>
              <option value="3" selected>3 – 7 years</option>
              <option value="4">7 – 15 years</option>
              <option value="5">15+ years</option>
            </select>
          </div>
          <div class="form-group">
            <label>Primary Financial Goal</label>
            <select id="goalSelect">
              <option value="1">Capital Preservation</option>
              <option value="2">Regular Income</option>
              <option value="3" selected>Balanced Growth</option>
              <option value="4">Wealth Creation</option>
              <option value="5">Aggressive Growth</option>
            </select>
          </div>
          <div class="form-group">
            <label>Emergency Fund</label>
            <select id="emergencySelect">
              <option value="0">No emergency fund</option>
              <option value="1">1 – 2 months' expenses</option>
              <option value="2" selected>3 – 6 months' expenses</option>
              <option value="3">6+ months' expenses</option>
            </select>
          </div>
        </div>
        <div class="form-panel" style="margin-top:1rem;">
          <h3>Investment Allocation (%)</h3>
          <p style="font-size:0.76rem;color:#6b7280;margin-bottom:1rem;">Enter the approximate percentage of your total investments in each asset class. These should sum to 100%.</p>
          <div class="inv-grid">
            <div class="form-group"><label>📈 Stocks / Equity</label><input type="number" id="stockPct" min="0" max="100" value="40"></div>
            <div class="form-group"><label>🏦 Mutual Funds</label><input type="number" id="mfPct" min="0" max="100" value="20"></div>
            <div class="form-group"><label>🥇 Gold / Sov. Bonds</label><input type="number" id="goldPct" min="0" max="100" value="10"></div>
